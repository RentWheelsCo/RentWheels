// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?
  password     String?
  profilePhoto String?
  licensePhoto String?
  role         String    @default("user")
  googleId String? @unique
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  vehicles     Vehicle[]
  bookings     Booking[]
  comments     Comment[]
  commentLikes CommentLike[]
  notifications Notification[]
}

model VehicleOption {
  id        Int      @id @default(autoincrement())
  type      String
  value     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  parentId  Int?

  parent    VehicleOption? @relation("VehicleOptionParent", fields: [parentId], references: [id])
  children  VehicleOption[] @relation("VehicleOptionParent")

  vehiclesAsType         Vehicle[] @relation("VehicleType")
  vehiclesAsBrand        Vehicle[] @relation("VehicleBrand")
  vehiclesAsModel        Vehicle[] @relation("VehicleModel")
  vehiclesAsCategory     Vehicle[] @relation("VehicleCategory")
  vehiclesAsTransmission Vehicle[] @relation("VehicleTransmission")
  vehiclesAsFuelType     Vehicle[] @relation("VehicleFuelType")
  vehiclesAsLocation     Vehicle[] @relation("VehicleLocation")

  @@unique([type, value])
}

model Vehicle {
  id              Int           @id @default(autoincrement())
  ownerId         Int
  typeId          Int
  brandId         Int
  modelId         Int
  categoryId      Int
  transmissionId  Int
  fuelTypeId      Int
  locationId      Int
  year            Int
  dailyPrice      Float
  seatingCapacity Int
  description     String?
  availabilityStatus String @default("AVAILABLE")
  photos          String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner        User          @relation(fields: [ownerId], references: [id])
  type         VehicleOption @relation("VehicleType", fields: [typeId], references: [id])
  brand        VehicleOption @relation("VehicleBrand", fields: [brandId], references: [id])
  model        VehicleOption @relation("VehicleModel", fields: [modelId], references: [id])
  category     VehicleOption @relation("VehicleCategory", fields: [categoryId], references: [id])
  transmission VehicleOption @relation("VehicleTransmission", fields: [transmissionId], references: [id])
  fuelType     VehicleOption @relation("VehicleFuelType", fields: [fuelTypeId], references: [id])
  location     VehicleOption @relation("VehicleLocation", fields: [locationId], references: [id])
  bookings     Booking[]
  comments     Comment[]
}

model Booking {
  id            Int      @id @default(autoincrement())
  vehicleId     Int
  renterId      Int
  pickupDate    DateTime
  returnDate    DateTime
  insuranceType String
  status        String   @default("PENDING")
  payment       Payment?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  renter  User    @relation(fields: [renterId], references: [id])

  @@index([vehicleId, pickupDate, returnDate])
  @@index([renterId])
}

model Payment {
  id                    Int      @id @default(autoincrement())
  bookingId             Int      @unique
  stripeCheckoutSession String?  // Made nullable
  stripePaymentIntent   String?
  amount                Float
  currency              String   @default("usd")
  status                String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([stripeCheckoutSession]) // Conditional unique
}

model Comment {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  userId    Int
  parentId  Int?
  content   String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentThread")
  likes   CommentLike[]

  @@index([vehicleId, createdAt])
  @@index([parentId, createdAt])
  @@index([userId])
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  message   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

